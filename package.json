{
  "name": "devnest-backend",
  "version": "1.0.0",
  "description": "DevNest is a tool for the Developers",
  "scripts": {
    "build": "rm -f .tsbuildinfo && npm run generate && nest build -b tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "start:worker:dev": "ts-node src/worker.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix --cache --cache-location .eslintcache",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\" --cache --cache-location .eslintcache",
    "generate": "npx prisma generate --schema ./prisma/postgres/schema.prisma",
    "prisma:validate": "npx prisma validate --schema=./prisma/postgres/schema.prisma",
    "migrate:pg": "npx prisma migrate dev --schema=./prisma/postgres/schema.prisma",
    "migrate:deploy": "npx prisma migrate deploy --schema=./prisma/postgres/schema.prisma",
    "test:manual": "node scripts/test_all_apis.js",
    "test:auth": "npx tsx scripts/verify-auth.ts",
    "test:ci": "npm run lint:check && npm run build && npm run prisma:validate",
    "test:ci:docker": "docker compose -f docker-compose.ci.yml up --build --abort-on-container-exit",
    "ci": "npm run test:ci:docker",
    "test:cd": "docker build . -t devnest-test",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:ci": "jest --config ./test/jest-e2e.json --forceExit",
    "test:e2e:cov": "jest --config ./test/jest-e2e.json --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.12",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.12",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.16.0",
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.66.5",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "piscina": "^5.1.4",
    "redis": "^5.10.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.13",
    "prisma": "^7.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^6.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "jest-mock-extended": "^4.0.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
